<?xml version="1.0" encoding="utf-8"?>


<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ① Background image (day / night switched in code) -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:src="@drawable/bg_day" />

    <!-- ② Full-screen dim overlay for readability -->
    <View
        android:id="@+id/viewOverlay"
        android:layout_width="444dp"
        android:layout_height="match_parent"
        android:background="#33000000" />

    <!-- ③ Scrollable content — sits BELOW the top bar in z-order -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!--  WEATHER SUMMARY HEADER                               -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="116dp"
                android:paddingBottom="28dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <!-- Large Temperature — tap opens OpenWeatherMap -->
                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--°"
                    android:textColor="#FFFFFF"
                    android:textSize="88sp"
                    android:letterSpacing="-0.03"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="12"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    tools:text="33°" />

                <!-- Weather Condition -->
                <TextView
                    android:id="@+id/tvCondition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#F0FFFFFF"
                    android:textSize="20sp"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="6"
                    tools:text="Hazy Sunshine" />

                <!-- RealFeel -->
                <TextView
                    android:id="@+id/tvRealFeel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RealFeel® --°"
                    android:textColor="#CCE0F0FF"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    tools:text="RealFeel® 34°" />

                <!-- Sunrise / Sunset row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sunrise"
                        android:contentDescription="Sunrise"
                        app:tint="#FFE0A0" />

                    <TextView
                        android:id="@+id/tvSunrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:-- AM"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:layout_marginStart="6dp"
                        android:shadowColor="#AA000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="4"
                        tools:text="6:12 AM" />

                    <Space
                        android:layout_width="36dp"
                        android:layout_height="1dp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_sunset"
                        android:contentDescription="Sunset"
                        app:tint="#FFA060" />

                    <TextView
                        android:id="@+id/tvSunset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:-- PM"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:layout_marginStart="6dp"
                        android:shadowColor="#AA000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="4"
                        tools:text="6:45 PM" />
                </LinearLayout>
            </LinearLayout>


            <!--  CURRENT CONDITIONS — 4 inline cards, unique IDs     -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Conditions"
                    android:textColor="#EEFFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:layout_marginBottom="12dp" />

                <!-- Row 1: AQI + UV -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- AQI -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardAqi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#22FFFFFF"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvAqiTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AQI"
                                android:textColor="#CCEAFFFF"
                                android:textSize="13sp"
                                android:letterSpacing="0.08" />
                            <ImageView
                                android:id="@+id/ivAqiIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="AQI icon"
                                android:src="@drawable/ic_aqi"
                                app:tint="#FFFFFF" />
                            <TextView
                                android:id="@+id/tvAqiValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:text="Moderate" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- UV Index -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardUv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#22FFFFFF"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvUvTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="UV Index"
                                android:textColor="#CCEAFFFF"
                                android:textSize="13sp"
                                android:letterSpacing="0.08" />
                            <ImageView
                                android:id="@+id/ivUvIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="UV icon"
                                android:src="@drawable/ic_uv"
                                app:tint="#FFD54F" />
                            <TextView
                                android:id="@+id/tvUvValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:text="Moderate" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- Row 2: Wind + Humidity -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginTop="12dp">

                    <!-- Wind -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardWind"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#22FFFFFF"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvWindTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wind"
                                android:textColor="#CCEAFFFF"
                                android:textSize="13sp"
                                android:letterSpacing="0.08" />
                            <ImageView
                                android:id="@+id/ivWindIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="Wind icon"
                                android:src="@drawable/ic_wind"
                                app:tint="#FFFFFF" />
                            <TextView
                                android:id="@+id/tvWindValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:text="12 km/h" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Humidity -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardHumidity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#22FFFFFF"
                        app:cardElevation="0dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvHumidityTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Humidity"
                                android:textColor="#CCEAFFFF"
                                android:textSize="13sp"
                                android:letterSpacing="0.08" />
                            <ImageView
                                android:id="@+id/ivHumidityIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginTop="10dp"
                                android:contentDescription="Humidity icon"
                                android:src="@drawable/ic_humidity"
                                app:tint="#90CAF9" />
                            <TextView
                                android:id="@+id/tvHumidityValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                tools:text="64%" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  HOURLY FORECAST                                      -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hourly Forecast"
                    android:textColor="#EEFFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="10dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#22FFFFFF"
                    app:cardElevation="0dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHourlyForecast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_hourly_forecast"
                        tools:itemCount="6" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!--  6-DAY FORECAST                                       -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5-Day Forecast"
                    android:textColor="#EEFFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:shadowColor="#AA000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="10dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#22FFFFFF"
                    app:cardElevation="0dp">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDailyForecast"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_daily_forecast"
                        tools:itemCount="6" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ④ FIXED TOP BAR — declared LAST = highest z-order = always on top
         Gradient background hides any scroll content that slides behind it  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="48dp"
        android:paddingBottom="14dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_topbar_gradient">


        <!-- Location pin / change city button -->
        <ImageButton
            android:id="@+id/btnLocationChange"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_location_pin"
            android:contentDescription="Change location"
            app:tint="#FFFFFF" />

        <!-- City, State — centered between the two buttons -->
        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:letterSpacing="0.03"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="1"
            android:shadowRadius="6"
            android:singleLine="true"
            android:text="Fetching location…"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Refresh button -->
        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_refresh"
            android:contentDescription="Refresh"
            app:tint="#FFFFFF" />
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_settings_custom"
            android:contentDescription="Settings"
            app:tint="#FFFFFF" />
    </LinearLayout>

</FrameLayout>